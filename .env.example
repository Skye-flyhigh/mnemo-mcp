# Mnemo — Configuration
# Copy to .env and adjust as needed.

# SQLite database path (default: ~/.mnemo/memory.db)
MNEMO_DB_PATH=~/.mnemo/memory.db

# Ollama embedding model (default: nomic-embed-text)
MNEMO_EMBEDDING_MODEL=nomic-embed-text

# Ollama base URL (default: http://localhost:11434)
MNEMO_OLLAMA_URL=http://localhost:11434

# Embedding dimensions — must match your model (default: 768)
MNEMO_DIMENSIONS=768
