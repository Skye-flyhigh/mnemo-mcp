{
  "name": "mnemo-mcp",
  "version": "1.2.1",
  "description": "Portable cognitive memory MCP server with semantic search and decay",
  "type": "module",
  "bin": {
    "mnemo-mcp": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
