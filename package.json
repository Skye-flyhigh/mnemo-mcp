    "ollama",
    "openai",
    "embeddings",
    "model-context-protocol"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skye-flyhigh/mnemo-mcp.git"
  },
  "homepage": "https://github.com/skye-flyhigh/mnemo-mcp#readme",
  "bugs": {
    "url": "https://github.com/skye-flyhigh/mnemo-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^12.6.2",
    "sqlite-vec": "0.1.7-alpha.2",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3",
